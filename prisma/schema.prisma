generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_LINK")
}

model PersonalInfo {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  role         String[] // Array for multiple roles as requested
  bio          String[] // Stored as lines for editor view
  email        String?
  phone        String?
  location     String?
  githubLink   String?
  linkedinLink String?
  twitterLink  String?
  resumeLink   String?
  interests    String[] // Stored as lines for editor view
}

model Project {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  imageLink   String?
  description String
  techStack   String[]
  link        String?
  date        String?
  featured    Boolean  @default(false)
  order       Int      @default(0)
}

model Education {
  id          String  @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  institution String
  percentage  String?
  year        String?
  type        String  @default("university") // high-school, university, etc.
}

model Certificate {
  id      String  @id @default(auto()) @map("_id") @db.ObjectId
  name    String
  issuer  String
  link    String?
  img     String?
  date    String?
}

type SkillItem {
  name   String
  iconId String?
}

model SkillCategory {
  id     String      @id @default(auto()) @map("_id") @db.ObjectId
  name   String
  skills SkillItem[]
}

model TechIcon {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String // e.g. "React"
  icon  String // e.g. "⚛"
}

model Message {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  senderName  String
  senderEmail String
  message     String
  read        Boolean  @default(false)
  time        DateTime @default(now())
}

// NextAuth Models
model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  name          String?
  email         String   @unique
  emailVerified DateTime?
  image         String?
  password      String?   // For Credentials provider
  
  // 2FA Fields
  otp           String?
  otpExpires    DateTime?
  
  accounts      Account[]
  sessions      Session[]
}

model VerificationToken {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Experience {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  company     String
  role        String
  location    String?
  duration    String   // e.g., "Jan 2023 - Present"
  description String[] // Bullet points for experience details
  techIds     String[] @db.ObjectId
  order       Int      @default(0)
}

model SocialLinks{
  id String @id @default(auto()) @map("_id") @db.ObjectId
  platform String
  url String
  iconId String?
}